        <fullname>Nintendo GameCube</fullname>
        <path>%ROMPATH%/Nintendo - GameCube</path>
        <extension>.iso .gcm .ciso</extension>
        <command>bash -c 'dolphin-emu -b -e "$1" -c "Dolphin.Display.Fullscreen=True"' _ %ROM%</command>
        <platform>gamecube</platform>
        <theme>gamecube</theme>
    </system>

